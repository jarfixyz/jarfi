# Solana RPC endpoint (defaults to devnet if not set)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Server wallet secret key as a JSON byte array
# Generate one: node -e "const {Keypair}=require('@solana/web3.js');console.log(JSON.stringify(Array.from(Keypair.generate().secretKey)))"
# Then fund it on devnet: solana airdrop 2 <pubkey> --url devnet
SERVER_WALLET_SECRET=

# MoonPay webhook secret for legacy experiments only
MOONPAY_SECRET_KEY=

# Guardarian webhook endpoint to configure in partner dashboard:
# https://your-backend.example.com/guardarian-webhook

# Transak Partner Access Token (used to verify webhook JWT)
# Find in Transak dashboard → Settings → API credentials
TRANSAK_API_SECRET=

# Transak webhook endpoint to configure in Transak dashboard:
# https://your-backend.example.com/transak-webhook

# Port (defaults to 3001)
PORT=3001
