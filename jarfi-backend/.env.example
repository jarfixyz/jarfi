# Solana RPC endpoint (defaults to devnet if not set)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Server wallet secret key as a JSON byte array
# Generate one: node -e "const {Keypair}=require('@solana/web3.js');console.log(JSON.stringify(Array.from(Keypair.generate().secretKey)))"
# Then fund it on devnet: solana airdrop 2 <pubkey> --url devnet
SERVER_WALLET_SECRET=

# MoonPay webhook secret for HMAC signature verification
# Find in MoonPay dashboard → Developers → Webhooks
MOONPAY_SECRET_KEY=

# Port (defaults to 3001)
PORT=3001
