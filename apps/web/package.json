{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "cf:dev": "opennextjs-cloudflare build && node scripts/patch-handler.mjs && wrangler dev",
    "cf:deploy": "opennextjs-cloudflare build && node scripts/patch-handler.mjs && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply jarfi-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply jarfi-db --remote"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@jarfi/sdk": "workspace:*",
    "@opennextjs/cloudflare": "^1.8.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@solana/pay": "^0.2.6",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-phantom": "^0.9.29",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-solflare": "^0.6.33",
    "@solana/web3.js": "^1.98.4",
    "@tailwindcss/postcss": "^4.1.0",
    "@transak/transak-sdk": "^4.0.2",
    "bignumber.js": "^9.1.0",
    "bs58": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.40.0",
    "framer-motion": "^11",
    "geist": "^1.5.0",
    "nanoid": "^5.1.0",
    "next": "^15.5.0",
    "postcss": "^8.5.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-easy-crop": "^5.0.8",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.1.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.1",
    "better-sqlite3": "^12.0.0",
    "drizzle-kit": "^0.31.0",
    "jsdom": "^26.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.20.0"
  }
}
